        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VFE_TableStoveLargeGas"]/description</xpath>
        <value>
            <description>A large size magmatic gas-powered manufacturing stove as well as multiple ovens to prepare meals and cook significantly faster.</description>
        </value>
    </Operation>

    <!-- VFE_TableStoveLargeGas -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VFE_TableStoveLargeGas"]/label</xpath>
        <value>
            <label>Large Magmatic Stove</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VFE_TableStoveLargeGas"]/description</xpath>
        <value>
            <description>A large size magmatic gas-powered manufacturing stove as well as multiple ovens to prepare meals and cook significantly faster.</description>
        </value>
    </Operation>
