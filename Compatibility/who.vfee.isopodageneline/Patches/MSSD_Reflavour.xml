        <xpath>Defs/ThingDef[defName="SW_Electrictick"]/label</xpath>
        <value>
            <label>Chaurus Chitterling</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="SW_Electrictick"]/label</xpath>
