    <!-- SW_Electrictick -> Megascarab, Royal Megascarab, Locust -->
    <!-- Core Megascarab -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="Megascarab"]/lifeStages</xpath>
        <value>
            <lifeStages>
                <li>
                    <bodyGraphicData>
                        <texPath>Things/Pawn/Animal/SW_GrenadeBug/SW_GrenadeBug</texPath>
                        <drawSize>1.5</drawSize>
                        <color>(66,73,81)</color>
                        <shaderType>CutoutComplex</shaderType>
                    </bodyGraphicData>
                    <dessicatedBodyGraphicData>
                        <texPath>Things/Pawn/Animal/SW_GrenadeBug/SW_Dessicated_EngineerBug</texPath>
                        <drawSize>1.5</drawSize>
                    </dessicatedBodyGraphicData>
                </li>
            </lifeStages>
        </value>
    </Operation>
