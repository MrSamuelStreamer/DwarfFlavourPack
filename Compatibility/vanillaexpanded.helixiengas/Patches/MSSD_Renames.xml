<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- VHGE_GasSunLamp -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasSunLamp"]/label</xpath>
        <value>
            <label>Magmatic Sun Lamp</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasSunLamp"]/description</xpath>
        <value>
            <description>An industrial lamp which lights an area brightly enough to grow crops, but consumes a medium amount of magmatic fluid. Automatically turns itself off at night.</description>
        </value>
    </Operation>

    <!-- VHGE_GasLamp -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasLamp"]/label</xpath>
