            <label>Magmatic Lamp</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasLamp"]/description</xpath>
        <value>
            <description>A magmatic fluid powered standing lamp that lights an area. People need light to move and work at full speed. Needs to be connected to the magmatic fluid network. Can be safely placed outdoors.</description>
        </value>
    </Operation>

    <!-- VHGE_GasWallLamp -->
