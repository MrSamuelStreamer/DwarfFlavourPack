    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_HelixienPump"]/description</xpath>
        <value>
            <description>An extractor machine mounted on a geothermal pocket of magmatic gas. This machine pumps out valuable gas and needs to be connected to other gas-based utilities using the pipe network.</description>
        </value>
    </Operation>

    <!-- VHGE_HelixienGenerator -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_HelixienGenerator"]/label</xpath>
