<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- VHGE_GasSunLamp -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasSunLamp"]/label</xpath>
        <value>
            <label>Magmatic Sun Lamp</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasSunLamp"]/description</xpath>
        <value>
            <description>An industrial lamp which lights an area brightly enough to grow crops, but consumes a medium amount of magmatic gas. Automatically turns itself off at night.</description>
        </value>
    </Operation>

    <!-- VHGE_GasLamp -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasLamp"]/label</xpath>
        <value>
            <label>Magmatic Lamp</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasLamp"]/description</xpath>
        <value>
            <description>A magmatic gas-powered standing lamp that lights an area. People need light to move and work at full speed. Needs to be connected to the magmatic network. Can be safely placed outdoors.</description>
        </value>
    </Operation>

    <!-- VHGE_GasWallLamp -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasWallLamp"]/label</xpath>
        <value>
            <label>Magmatic Wall Lamp</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasWallLamp"]/description</xpath>
        <value>
            <description>A magmatic gas-powered wall light that lights an area. People need light to move and work at full speed. Needs to be connected to the magmatic gas network. Can be safely placed outdoors.</description>
        </value>
    </Operation>

    <!-- VHGE_GasFloodlight -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasFloodlight"]/label</xpath>
        <value>
            <label>Magmatic Floodlight</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasFloodlight"]/description</xpath>
        <value>
            <description>A magmatic gas-powered tall floodlight that lights a massive area. People need light to move and work at full speed. It doesn't shine bright enough to grow crops. Needs to be connected to the magmatic gas network. Can be safely placed outdoors.</description>
        </value>
    </Operation>

    <!-- VHGE_GasOperatedPodLauncher -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasOperatedPodLauncher"]/label</xpath>
        <value>
            <label>Magmatic Pod Launcher</label> <!-- Probably unused due to tech level -->
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasOperatedPodLauncher"]/description</xpath>
        <value>
            <description>A fueling port for launching one transport pod. Pod launchers can launch as a group - but the launchers must be placed adjacent to each other. Requires connection to a magmatic gas system.</description>
        </value>
    </Operation>

    <!-- VHGE_GasGeyser -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasGeyser"]/label</xpath>
        <value>
            <label>Magmatic Geyser</label>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VHGE_GasGeyser"]/description</xpath>
        <value>
            <description>A natural source of high-pressure magmatic gas. Pumps can be built on top to extract the magmatic gasses.</description>
        </value>
    </Operation>

