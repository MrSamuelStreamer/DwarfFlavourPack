<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- LavaGenerator from Lava Power mod -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="LavaGenerator"]/researchPrerequisites</xpath>
        <value>
            <li>VHGE_GasExtraction</li>
        </value>
    </Operation>
    
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="LavaGenerator"]/costList</xpath>
        <value>
            <costList>
                <Steel>500</Steel>
                <RF_Bronze>500</RF_Bronze>
                <ComponentIndustrial>5</ComponentIndustrial>
            </costList>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="LavaGenerator"]/graphicData/drawSize</xpath>
        <value>
           <drawSize>(3,3)</drawSize>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="LavaGenerator"]/size</xpath>
        <value>
           <size>(3,3)</size>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="LavaGenerator"]/rotatable</xpath>
        <value>
           <rotatable>false</rotatable>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="LavaGenerator"]/comps</xpath>
        <value>
           <comps>
            <li Class="CompProperties_Glower">
                <glowRadius>8</glowRadius>
                <glowColor>(255,248,214,255)</glowColor>
            </li>
            <li Class="CompProperties_Power">
                <compClass>LavaPower.CompPowerPlantLava</compClass>
                <basePowerConsumption>-800</basePowerConsumption>
                <transmitsPower>true</transmitsPower>
            </li>
            <li Class="CompProperties_Breakdownable"/>
            </comps>
        </value>
    </Operation>
</Patch>