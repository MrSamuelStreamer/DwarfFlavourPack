		<label>castle gate (ridiculous)</label>
		<description>An incredibly resistant door made out of oversized stone blocks, with a latticed grille protecting the passage. Very slow to build. It’s a good choice if you want to keep the enemies out - or in. The door requires walls on either side to function. Castle gates take a long time to open.</description>
		<thingClass>VFEMedieval.CastleGate</thingClass>
		<statBases>
			<WorkToBuild>17000</WorkToBuild>
			<MaxHitPoints>3300</MaxHitPoints>
			<DoorOpenSpeed>0.5</DoorOpenSpeed>
		</statBases>
		<graphicData>
			<texPath>Things/Building/Doors/CastleGate4x1_Mover</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<damageData>
				<enabled>false</enabled>
			</damageData>
		</graphicData>
		<uiIconPath>Things/Building/Doors/CastleGate4x1_MenuIcon_south</uiIconPath>
		<useBlueprintGraphicAsGhost>true</useBlueprintGraphicAsGhost>
		<size>(8,1)</size>
		<rotatable>true</rotatable>
		<costStuffCount>700</costStuffCount>
		<stuffCategories Inherit="False">
			<li>Stony</li>
		</stuffCategories>
		<costList>
			<Steel>320</Steel>
		</costList>
		<building>
			<blueprintClass>Blueprint_Build</blueprintClass>
			<blueprintGraphicData>
				<texPath>Things/Building/Doors/CastleGate4x1_MenuIcon</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>EdgeDetect</shaderType>
				<drawSize>(8.6, 5.1)</drawSize>
        <drawOffset>(0,0,0.4)</drawOffset>
