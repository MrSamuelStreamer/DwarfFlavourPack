<?xml version="1.0" encoding="utf-8"?>
<Defs>

  	<ThingDef ParentName="DoorBase">
		<defName>MSSD_8x1_VFEM2_4x1CastleDoor</defName>
		<label>castle door (ridiculous)</label>
		<description>An incredibly resistant door made out of oversized stone blocks. Very slow to build. It’s a good choice if you want to keep the enemies out - or in. The door requires walls on either side to function.</description>
		<thingClass>Building_MultiTileDoor</thingClass>
		<statBases>
			<WorkToBuild>20700</WorkToBuild>
			<MaxHitPoints>3200</MaxHitPoints>
			<DoorOpenSpeed>0.8</DoorOpenSpeed>
		</statBases>
		<graphicData>
			<texPath>Things/Building/Doors/CastleDoor4x1_Mover</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<damageData>
				<enabled>false</enabled>
			</damageData>
		</graphicData>
		<uiIconPath>Things/Building/Doors/CastleDoor4x1_MenuIcon_south</uiIconPath>
		<useBlueprintGraphicAsGhost>true</useBlueprintGraphicAsGhost>
		<size>(8,1)</size>
		<rotatable>true</rotatable>
		<costStuffCount>700</costStuffCount>
		<stuffCategories Inherit="False">
			<li>Stony</li>
		</stuffCategories>
		<building>
			<blueprintClass>Blueprint_Build</blueprintClass>
			<blueprintGraphicData>
				<texPath>Things/Building/Doors/CastleDoor4x1_MenuIcon</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>EdgeDetect</shaderType>
				<drawSize>(8.6, 5.1)</drawSize>
        <drawOffset>(0,0,0.4)</drawOffset>
			</blueprintGraphicData>
			<isSupportDoor>true</isSupportDoor>
			<doorTopGraphic>
				<texPath>Things/Building/Doors/CastleDoor4x1_Top</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<drawSize>(9.1, 2.3)</drawSize>
			</doorTopGraphic>
			<doorSupportGraphic>
				<texPath>Things/Building/Doors/CastleDoor4x1_Support</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<drawSize>(9.1, 2.3)</drawSize>
			</doorSupportGraphic>
			<soundDoorOpenManual>VFEM2_CastleGate_OpenManual</soundDoorOpenManual>
			<soundDoorCloseManual>VFEM2_CastleGate_CloseManual</soundDoorCloseManual>
		</building>
		<researchPrerequisites>
			<li>VFEM2_MedievalArchitecture</li>
		</researchPrerequisites>
		<placeWorkers>
			<li>PlaceWorker_MultiCellDoor</li>
		</placeWorkers>
	</ThingDef>

  <ThingDef ParentName="DoorBase">
