<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <DutyDef>
        <defName>DFP_LoadAndEnterTunnel</defName>
        <thinkNode Class="ThinkNode_Priority">
            <subNodes>
                <!-- Basic needs -->
                <li Class="ThinkNode_Subtree">
                    <treeDef>SatisfyVeryUrgentNeeds</treeDef>
                </li>

                <!-- Haul to portal -->
                <li Class="DwarfFlavourPack.JobGiver_HaulToTunnel" />

                <!-- Drop items if you're assigned to unload everything -->
                <!-- (before entering the portal!) -->
                <li Class="JobGiver_UnloadYourInventory" />

                <!-- Enter -->
                <li Class="DwarfFlavourPack.JobGiver_EnterTunnel" />
            </subNodes>
        </thinkNode>
    </DutyDef>

    <JobDef>
        <defName>DFP_HaulToTunnel</defName>
        <driverClass>DwarfFlavourPack.JobDriver_HaulToTunnel</driverClass>
        <reportString>hauling TargetA.</reportString>
        <suspendable>false</suspendable>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
        <dropThingBeforeJob>false</dropThingBeforeJob>
    </JobDef>

    <WorkGiverDef>
        <defName>DFP_HaulToTunnel</defName>
        <label>haul to map</label>
        <giverClass>DwarfFlavourPack.WorkGiver_HaulToTunnel</giverClass>
        <workType>Hauling</workType>
        <verb>load</verb>
        <gerund>loading</gerund>
        <priorityInType>105</priorityInType>
        <requiredCapacities>
            <li>Manipulation</li>
        </requiredCapacities>
    </WorkGiverDef>
    
    <JobDef>
        <defName>DFP_EnterTunnel</defName>
        <driverClass>DwarfFlavourPack.JobDriver_EnterTunnel</driverClass>
        <dropThingBeforeJob>false</dropThingBeforeJob>
        <carryThingAfterJob>true</carryThingAfterJob>
        <reportString>entering TargetA.</reportString>
    </JobDef>

    <JobDef>
        <defName>CarryDownedPawnToPortal</defName>
        <driverClass>DwarfFlavourPack.JobDriver_TakeAndEnterTunnel</driverClass>
        <reportString>carrying TargetA.</reportString>
        <casualInterruptible>false</casualInterruptible>
        <checkOverrideOnDamage>Never</checkOverrideOnDamage>
        <carryThingAfterJob>true</carryThingAfterJob>
    </JobDef>
</Defs>