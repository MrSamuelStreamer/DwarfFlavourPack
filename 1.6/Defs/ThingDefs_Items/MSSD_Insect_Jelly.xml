<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- Just misc flavourful fluff by itself, intended to be used with Resource Dictionary to merge over core InsectJelly ThingDef -->
  <ThingDef ParentName="OrganicProductBase">
    <defName>MSSD_InsectJelly</defName>
    <label>Chaurus jelly</label>
    <description>A vivid blue jelly stored and used as food by Chaurus hives. It is smooth, rich, and fulfills the recreation need of those who consume it. Because of its unique biological properties, it can nourish almost any creature and never rots.</description>
    <possessionCount>10</possessionCount>
    <graphicData>
      <texPath>Things/Item/Food/Jelly</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <socialPropernessMatters>true</socialPropernessMatters>
    <statBases>
      <MarketValue>8.0</MarketValue>
      <Mass>0.025</Mass>
      <Nutrition>0.05</Nutrition>
      <FoodPoisonChanceFixedHuman>0.02</FoodPoisonChanceFixedHuman>
    </statBases>
    <ingestible>
      <foodType>AnimalProduct</foodType>
      <preferability>MealFine</preferability>
      <joy>0.08</joy>
      <joyKind>Gluttonous</joyKind>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>Meal_Eat</ingestSound>
      <lowPriorityCaravanFood>true</lowPriorityCaravanFood>
      <babiesCanIngest>true</babiesCanIngest>
    </ingestible>
    <thingCategories>
      <li>AnimalProductRaw</li>
    </thingCategories>
    <allowedArchonexusCount>150</allowedArchonexusCount>
  </ThingDef>
</Defs>