<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- BrendaKillsBarbas: a mysterious woman executes her dog, then attacks the caravan.
       Letter text is deliberately vague — the player discovers what happened on the map. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanBrendaKillsBarbas</defName>
    <label>tunnel delay</label>
    <category>ThreatBig</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_BrendaKillsBarbas</workerClass>
    <baseChance>100</baseChance>
    <minRefireDays>60</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>The tunnel caravan's minecarts have ground to a halt somewhere in the underground passages. Something is blocking the way ahead.\n\nThe caravan has been forced to stop and investigate.</letterText>
    <letterDef>ThreatBig</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>


  <!-- ForgottenOssuary: a natural chamber holds an ancient shrine and the skeletons
       of those who came to worship and never left. Non-combat discovery event.
       FireOncePerGame = true — set in the worker class. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanForgottenOssuary</defName>
    <label>tunnel delay</label>
    <category>Misc</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanForgottenOssuary</workerClass>
    <baseChance>0.5</baseChance>
    <minRefireDays>30</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>The tunnel caravan's minecarts have ground to a halt somewhere in the underground passages. Something is blocking the way ahead.\n\nThe caravan has been forced to stop and investigate.</letterText>
    <letterDef>NeutralEvent</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>


  <!-- CaveIn: the tunnel ceiling collapses, sealing the passage with fallen rock.
       Non-combat; the caravan must mine through the debris before they can reform.
       Reform is blocked by CaveInReformBlocker_Patch until MapComponent_CaveInBlocker.IsCleared. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanCaveIn</defName>
    <label>tunnel delay</label>
    <category>Misc</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanCaveIn</workerClass>
    <baseChance>0</baseChance>
    <minRefireDays>30</minRefireDays>
    <letterLabel>Tunnel collapse</letterLabel>
    <letterText>A deep crack and rumble shakes the tunnel. Rock and earth pour from the ceiling, sealing the passage ahead.\n\nThe caravan is trapped. The debris must be cleared before they can move on.</letterText>
    <letterDef>NeutralEvent</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>


  <!-- TradingCaravan: a friendly trading outfit is encountered inside the tunnel.
       Non-combat; player trades at leisure and reforms normally whenever ready. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanTradingCaravan</defName>
    <label>tunnel delay</label>
    <category>Misc</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanTradingCaravan</workerClass>
    <baseChance>1.5</baseChance>
    <minRefireDays>15</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>Muffled voices drift through the tunnel walls ahead. The minecart slows.\n\nA trading outfit has stopped to rest in a wider chamber deeper in the passage. They seem friendly — and they have goods to sell.</letterText>
    <letterDef>NeutralEvent</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>


  <!-- AbandonedCache: scattered cargo from a previous expedition. No combat; pure loot event. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanAbandonedCache</defName>
    <label>tunnel delay</label>
    <category>Misc</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanAbandonedCache</workerClass>
    <baseChance>1.0</baseChance>
    <minRefireDays>25</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>The minecart rolls to a stop. Something is blocking the passage — or rather, something was left there long ago.\n\nAbandoned cargo sits in a natural alcove. Whoever left it is gone. The supplies remain.</letterText>
    <letterDef>NeutralEvent</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>


  <!-- TollCollector: a lone armed figure demands silver to let the caravan pass.
       Non-combat by default; escalates to assault if the player refuses. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanTollCollector</defName>
    <label>tunnel delay</label>
    <category>Misc</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanTollCollector</workerClass>
    <baseChance>0.4</baseChance>
    <minRefireDays>40</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>The minecart's lights fall on a figure in the passage. They are armed and they are waiting.\n\nThey want payment to let the caravan pass. They seem prepared to enforce the toll.</letterText>
    <letterDef>NeutralEvent</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>


  <!-- AncientDefences: dormant mechanoid sentinels activate when the caravan passes.
       Combat event; mechanoids fight to destruction (no timeout or flee). -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanAncientDefences</defName>
    <label>tunnel delay</label>
    <category>ThreatSmall</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanAncientDefences</workerClass>
    <baseChance>0.5</baseChance>
    <minRefireDays>30</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>The minecart's lights sweep across worked stone — and something moves in the dark.\n\nDormant mechanoid sentinels, silent for centuries, have detected the caravan. They are activating.</letterText>
    <letterDef>ThreatSmall</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>

  <!-- UndergroundShrine: an ancient altar in a domed chamber. FireOncePerGame = true. -->
  <IncidentDef>
    <defName>DFP_TunnelCaravanUndergroundShrine</defName>
    <label>tunnel delay</label>
    <category>Misc</category>
    <targetTags>
      <li>DFP_TunnelEntrance</li>
    </targetTags>
    <workerClass>DwarfFlavourPack.IncidentWorker_TunnelCaravanUndergroundShrine</workerClass>
    <baseChance>0.3</baseChance>
    <minRefireDays>90</minRefireDays>
    <letterLabel>Tunnel delay</letterLabel>
    <letterText>The tunnel opens into a domed chamber. At its centre stands a stone altar — old, silent, covered in offerings left by hands long dead.\n\nThe caravan has stopped. Nobody moves.</letterText>
    <letterDef>NeutralEvent</letterDef>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>

</Defs>
