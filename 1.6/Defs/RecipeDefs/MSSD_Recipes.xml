		<targetCountAdjustment>5</targetCountAdjustment>
		<researchPrerequisites>
			<li>VHGE_GasExtraction</li>
		</researchPrerequisites>
		<recipeUsers>
			<li>VFE_TableSmithyLargeGas</li>
			<li>VHGE_GasPoweredSmithy</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DankPyon_ComponentBasic</li>
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RF_Bronze</li>
					</thingDefs>
				</filter>
				<count>120</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DankPyon_ComponentBasic</li>
				<li>RF_Bronze</li>
			</thingDefs>
		</fixedIngredientFilter>
