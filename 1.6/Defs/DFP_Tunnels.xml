<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <WorldGenStepDef>
        <defName>DFP_TunnelEntrances</defName>
        <order>551</order>
        <worldGenStep Class="DwarfFlavourPack.WorldGenStep_TunnelEntrances">
            <tunnelSitesPer100kTiles>8~24</tunnelSitesPer100kTiles>
        </worldGenStep>
    </WorldGenStepDef>
    
    <WorldGenStepDef>
        <defName>DFP_Tunnels</defName>
        <order>651</order>
        <worldGenStep Class="DwarfFlavourPack.WorldGenStep_Tunnels" />
    </WorldGenStepDef>
    
    <DwarfFlavourPack.TunnelDef>
        <defName>DFP_Tunnel</defName>
        <label>tunnel</label>
        <distortionFrequency>0.5</distortionFrequency>
        <distortionIntensity>0.2</distortionIntensity>
        <worldTransitionGroup>Dirt</worldTransitionGroup>
    </DwarfFlavourPack.TunnelDef>
    
    <DwarfFlavourPack.TunnelWorldLayerDef>
        <defName>Stone</defName>
        <order>280</order>
        <color>(0.545, 0.27, 0.074)</color>
    </DwarfFlavourPack.TunnelWorldLayerDef>

    <PrefabDef>
        <defName>DFP_TunnelEntrancePrefab</defName>
        <size>(5,5)</size>
        <things>
            <DFP_TunnelEntrance>
                <position>(0, 0, 0)</position>
            </DFP_TunnelEntrance>
        </things>
    </PrefabDef>

    <StructureLayoutDef>
        <defName>DFP_TunnelEntranceStructure</defName>
        <workerClass>LayoutWorker_SimpleRuin</workerClass>
        <canHaveMultipleLayoutsInRoom>true</canHaveMultipleLayoutsInRoom>

        <roomDefs>
            <AncientRuinsCryptosleepCasketNoThreat />
        </roomDefs>
    </StructureLayoutDef>


    <GenStepDef>
        <defName>DFP_PlaceTunnelEntrance</defName>
        <order>400</order>
        <genStep Class="DwarfFlavourPack.GenStep_PlaceTunnelEntrance"/>
        <linkWithSite>DFP_TunnelEntranceSitePart</linkWithSite>
    </GenStepDef>
    
    <MapGeneratorDef ParentName="MapCommonBase">
        <defName>DFP_TunnelEntrance</defName>
        <genSteps>
            <li>DFP_PlaceTunnelEntrance</li> 
            <li>RocksFromGrid_NoMinerals</li> <!-- This is ignored if we are landing via gravship -->
        </genSteps>
    </MapGeneratorDef>
    
    <IncidentTargetTagDef>
        <defName>DFP_TunnelEntrance</defName>
    </IncidentTargetTagDef>


    <WorldObjectDef ParentName="StaticWorldObjectBase">
        <defName>DFP_TunnelEntranceSite</defName>
        <label>tunnel access</label>
        <worldObjectClass>DwarfFlavourPack.TunnelEntrance</worldObjectClass>
        <mapGenerator>DFP_TunnelEntrance</mapGenerator>
        <expandingIconTexture>UI/DFP_TunnelIcon</expandingIconTexture>
        <texture>UI/DFP_TunnelIcon</texture>
        <IncidentTargetTags>
            <li>DFP_TunnelEntrance</li>
        </IncidentTargetTags>
        <mapGenerator>DFP_TunnelEntrance</mapGenerator>
        <nameMaker>DFP_TunnelEntranceNamer</nameMaker>
        <expandingIcon>true</expandingIcon>
        <expandingIconPriority>80</expandingIconPriority>
        <comps>
            <li Class="WorldObjectCompProperties_TimedDetectionRaids" />
            <li Class="WorldObjectCompProperties_ItemStashContents" />
            <li Class="WorldObjectCompProperties_FormCaravan" />
        </comps>
    </WorldObjectDef>
    
    <SitePartDef>
        <defName>DFP_TunnelEntranceSitePart</defName>
        <label>Tunnel Entrance</label>
        <description>A Tunnel Entrance.</description>
        <workerClass>DwarfFlavourPack.SitePartWorker_Tunnel</workerClass>
        <siteTexture>UI/DFP_TunnelIcon</siteTexture>
        <expandingIconTexture>UI/DFP_TunnelIcon</expandingIconTexture>
        <applyFactionColorToSiteTexture>false</applyFactionColorToSiteTexture>
        <showFactionInInspectString>false</showFactionInInspectString>
        <requiresFaction>false</requiresFaction>
        <approachOrderString>Enter {0}</approachOrderString>
        <approachingReportString>Entering {0}.</approachingReportString>
    </SitePartDef>

    <WorldObjectDef>
        <defName>DFP_TunnelCaravanWorldObject</defName>
        <label>tunnel caravan</label>
        <worldObjectClass>DwarfFlavourPack.WorldObject_TunnelCaravan</worldObjectClass>
        <texture>UI/DFP_MineCart</texture>
        <expandingIconTexture>UI/DFP_MineCart</expandingIconTexture>
        <expandingIcon>true</expandingIcon>
        <expandingIconPriority>100</expandingIconPriority>
    </WorldObjectDef>
</Defs>