<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <WorldGenStepDef>
        <defName>DFP_TunnelEntrances</defName>
        <order>551</order>
        <worldGenStep Class="DwarfFlavourPack.WorldGenStep_TunnelEntrances">
            <tunnelSitesPer100kTiles>8~24</tunnelSitesPer100kTiles>
        </worldGenStep>
    </WorldGenStepDef>
    
    <WorldGenStepDef>
        <defName>DFP_Tunnels</defName>
        <order>651</order>
        <worldGenStep Class="DwarfFlavourPack.WorldGenStep_Tunnels" />
    </WorldGenStepDef>
    
    <DwarfFlavourPack.TunnelDef>
        <defName>DFP_Tunnel</defName>
        <label>tunnel</label>
        <distortionFrequency>0.5</distortionFrequency>
        <distortionIntensity>0.2</distortionIntensity>
        <worldTransitionGroup>Dirt</worldTransitionGroup>
    </DwarfFlavourPack.TunnelDef>
    
    <DwarfFlavourPack.TunnelWorldLayerDef>
        <defName>Stone</defName>
        <order>280</order>
        <color>(0.545, 0.27, 0.074)</color>
    </DwarfFlavourPack.TunnelWorldLayerDef>

    <PrefabDef>
        <defName>DFP_TunnelEntrancePrefab</defName>
        <size>(5,5)</size>
        <things>
            <DFP_TunnelEntrance>
                <position>(0, 0, 0)</position>
            </DFP_TunnelEntrance>
        </things>
    </PrefabDef>

    <StructureLayoutDef>
        <defName>DFP_TunnelEntranceStructure</defName>
        <workerClass>LayoutWorker_SimpleRuin</workerClass>
        <canHaveMultipleLayoutsInRoom>true</canHaveMultipleLayoutsInRoom>

        <roomDefs>
            <AncientRuinsCryptosleepCasketNoThreat />
        </roomDefs>
    </StructureLayoutDef>


    <GenStepDef>
        <defName>DFP_PlaceTunnelEntrance</defName>
        <order>400</order>
        <genStep Class="DwarfFlavourPack.GenStep_PlaceTunnelEntrance"/>
        <linkWithSite>DFP_TunnelEntranceSitePart</linkWithSite>
    </GenStepDef>

    <!-- Overrides biome terrain to cave floor + thick mountain roofing. Runs after Terrain (210). -->
    <GenStepDef>
        <defName>DFP_TunnelCaveSetup</defName>
        <order>230</order>
        <genStep Class="DwarfFlavourPack.GenStep_TunnelCaveSetup"/>
    </GenStepDef>

    <!--
        Carves underground cave corridors into MapGenerator.Caves before
        Underground_RocksFromGrid (order 200) runs.

        Replicates TileMutatorWorker_UndergroundCave.GeneratePostElevationFertility,
        which is normally triggered via pocketMapProperties.tileMutators. That path
        only fires when isPocketMap=true; caravan attack maps use isPocketMap=false,
        so no mutators are applied and MapGenerator.Caves stays all-zero without this step.
    -->
    <GenStepDef>
        <defName>DFP_TunnelCaravanCaves</defName>
        <order>15</order>
        <genStep Class="DwarfFlavourPack.GenStep_TunnelCaravanCaves"/>
    </GenStepDef>

    <MapGeneratorDef ParentName="MapCommonBase">
        <defName>DFP_TunnelEntrance</defName>
        <genSteps>
            <!-- Dense rock blotches give an underground cave feel -->
            <li>Underground_RocksFromGrid</li>
            <!-- Override surface terrain to cave floor + thick roof everywhere -->
            <li>DFP_TunnelCaveSetup</li>
            <!-- Clear area and place the entrance building -->
            <li>DFP_PlaceTunnelEntrance</li>
        </genSteps>
    </MapGeneratorDef>

    <!--
        Map generator for TunnelCaravan insect-attack encounters.
        Produces a cave-like arena: rough stone floor, thick overhead rock,
        and scattered rock formations for cover.

        IMPORTANT: Do NOT add pocketMapProperties. pocketMapProperties use a different
        creation path that requires isPocketMap=true, which caravan attack maps are NOT
        (they sit on a real world tile). Adding pocketMapProperties causes an
        InvalidCastException inside GetOrGenerateMap (previously documented as Issue 7).

        Do NOT inherit from MapCommonBase — child genSteps append to the parent list,
        so inheriting would silently run the entire surface pipeline before our steps.

        Gen steps (sorted by order):
          ElevationFertility (10)       — sets all cells to elevation 1.0 (all rock,
                                          because isUnderground=true)
          DFP_TunnelCaravanCaves (15)   — carves cave corridors into MapGenerator.Caves
                                          by replicating TileMutatorWorker_UndergroundCave.
                                          MutatorPostElevationFertility would do this via
                                          tileMutators, but those only run for isPocketMap=true.
          Underground_RocksFromGrid (200) — spawns rock Things on cells where Caves<=0
          DFP_TunnelCaveSetup (230)     — overrides terrain to rough stone, all cells
                                          get RoofRockThick
          FindPlayerStartSpot (850)     — finds a walkable player entry point
          RockChunks (970)              — loose chunks for cover and resources
          MutatorFinal (1600)           — required cleanup pass
          Fog                           — fog of war
    -->
    <MapGeneratorDef>
        <defName>DFP_TunnelEncounter</defName>
        <label>tunnel encounter</label>
        <isUnderground>true</isUnderground>
        <forceCaves>true</forceCaves>
        <genSteps>
            <li>ElevationFertility</li>
            <!-- DFP_TunnelCaravanCaves (order 15) carves corridors into MapGenerator.Caves
                 before Underground_RocksFromGrid (order 200) places rocks. Replaces
                 MutatorPostElevationFertility, which does nothing here because
                 isPocketMap=false means tileMutators are never applied. -->
            <li>DFP_TunnelCaravanCaves</li>
            <li>Underground_RocksFromGrid</li>
            <li>DFP_TunnelCaveSetup</li>
            <li>RockChunks</li>
            <li>FindPlayerStartSpot</li>
            <li>MutatorFinal</li>
            <li>Fog</li>
        </genSteps>
        <customMapComponents>
            <li>DwarfFlavourPack.MapComponent_TunnelCaravanState</li>
        </customMapComponents>
    </MapGeneratorDef>

    <!--
        Battlefield world object used as the map parent for TunnelCaravan insect-attack
        encounters.

        IMPORTANT: ParentName="Ambush" does NOT work — there is no abstract WorldObjectDef
        named "Ambush" in vanilla XML, so the inheritance silently produces an empty def
        with no worldObjectClass. This causes an InvalidCastException inside GetOrGenerateMap
        because it casts the result to MapParent.

        We explicitly mirror the vanilla AttackedNonPlayerCaravan def (worldObjectClass,
        isTempIncidentMapOwner, FormCaravan + TimedDetectionRaids comps) and set our
        own cave map generator.
    -->
    <WorldObjectDef ParentName="StaticWorldObjectBase">
        <defName>DFP_TunnelEncounterSite</defName>
        <label>tunnel encounter</label>
        <worldObjectClass>CaravansBattlefield</worldObjectClass>
        <mapGenerator>DFP_TunnelEncounter</mapGenerator>
        <texture>UI/DFP_TunnelIcon</texture>
        <expandingIconTexture>UI/DFP_TunnelIcon</expandingIconTexture>
        <expandingIcon>true</expandingIcon>
        <expandingIconPriority>80</expandingIconPriority>
        <isTempIncidentMapOwner>true</isTempIncidentMapOwner>
        <comps>
            <li Class="WorldObjectCompProperties_FormCaravan" />
            <li Class="WorldObjectCompProperties_TimedDetectionRaids" />
        </comps>
    </WorldObjectDef>
    
    <IncidentTargetTagDef>
        <defName>DFP_TunnelEntrance</defName>
    </IncidentTargetTagDef>


    <WorldObjectDef ParentName="StaticWorldObjectBase">
        <defName>DFP_TunnelEntranceSite</defName>
        <label>tunnel access</label>
        <worldObjectClass>DwarfFlavourPack.TunnelEntrance</worldObjectClass>
        <mapGenerator>DFP_TunnelEntrance</mapGenerator>
        <expandingIconTexture>UI/DFP_TunnelIcon</expandingIconTexture>
        <texture>UI/DFP_TunnelIcon</texture>
        <IncidentTargetTags>
            <li>DFP_TunnelEntrance</li>
        </IncidentTargetTags>
        <mapGenerator>DFP_TunnelEntrance</mapGenerator>
        <nameMaker>DFP_TunnelEntranceNamer</nameMaker>
        <expandingIcon>true</expandingIcon>
        <expandingIconPriority>80</expandingIconPriority>
        <comps>
            <li Class="WorldObjectCompProperties_TimedDetectionRaids" />
            <li Class="WorldObjectCompProperties_ItemStashContents" />
            <li Class="WorldObjectCompProperties_FormCaravan" />
        </comps>
    </WorldObjectDef>
    
    <SitePartDef>
        <defName>DFP_TunnelEntranceSitePart</defName>
        <label>Tunnel Entrance</label>
        <description>A Tunnel Entrance.</description>
        <workerClass>DwarfFlavourPack.SitePartWorker_Tunnel</workerClass>
        <siteTexture>UI/DFP_TunnelIcon</siteTexture>
        <expandingIconTexture>UI/DFP_TunnelIcon</expandingIconTexture>
        <applyFactionColorToSiteTexture>false</applyFactionColorToSiteTexture>
        <showFactionInInspectString>false</showFactionInInspectString>
        <requiresFaction>false</requiresFaction>
        <approachOrderString>Enter {0}</approachOrderString>
        <approachingReportString>Entering {0}.</approachingReportString>
    </SitePartDef>

    <!--
        GenStep for the Cave-In encounter: builds the deterministic tunnel + barrier
        rock layout and scatters loot. Runs after DFP_TunnelCaveSetup (230) so terrain
        and roofing are already set, and before FindPlayerStartSpot (850) so the start
        spot is found inside the open approach section.

        Used only by DFP_TunnelCaveIn — NOT included in DFP_TunnelEncounter.
    -->
    <GenStepDef>
        <defName>DFP_TunnelCaveInLayout</defName>
        <order>240</order>
        <genStep Class="DwarfFlavourPack.GenStep_TunnelCaveInLayout"/>
    </GenStepDef>

    <!--
        Map generator for the Cave-In encounter.
        Produces a fully deterministic layout: 100% solid rock outside a 5-wide
        central tunnel, with two 5-deep barrier bands ~20 cells either side of the
        Z-centre. The enclosed centre section and both approach sections are clear.

        Intentionally omits DFP_TunnelCaravanCaves and Underground_RocksFromGrid —
        random cave carving is not needed because GenStep_TunnelCaveInLayout builds
        the complete rock layout directly.

        Do NOT inherit from MapCommonBase — child genSteps append to the parent list
        and would silently run the entire surface pipeline.

        Gen steps (sorted by order):
          ElevationFertility (10)       — elevation data (required for isUnderground)
          DFP_TunnelCaveSetup (230)     — cave floor terrain + thick roof everywhere
          DFP_TunnelCaveInLayout (240)  — deterministic rock layout + loot scatter
          FindPlayerStartSpot (850)     — finds open cell in south approach section
          RockChunks (970)              — loose debris for flavour / resources
          MutatorFinal (1600)           — required cleanup pass
          Fog                           — fog of war
    -->
    <MapGeneratorDef>
        <defName>DFP_TunnelCaveIn</defName>
        <label>tunnel cave-in</label>
        <isUnderground>true</isUnderground>
        <forceCaves>true</forceCaves>
        <genSteps>
            <li>ElevationFertility</li>
            <li>DFP_TunnelCaveSetup</li>
            <li>DFP_TunnelCaveInLayout</li>
            <li>FindPlayerStartSpot</li>
            <li>RockChunks</li>
            <li>MutatorFinal</li>
            <li>Fog</li>
        </genSteps>
        <customMapComponents>
            <li>DwarfFlavourPack.MapComponent_TunnelCaravanState</li>
        </customMapComponents>
    </MapGeneratorDef>

    <!--
        World object for the Cave-In encounter map. Mirrors DFP_TunnelEncounterSite
        but points at the DFP_TunnelCaveIn map generator.

        CaravanIncidentUtility_Patch.UsesCaveMapForTunnelCaravan routes to this def
        when IncidentWorker_TunnelCaravanCaveIn.IsCaveIn is true.

        Also handles Notify_MyMapRemoved cleanup — the patch checks for both
        DFP_TunnelEncounterSite and DFP_TunnelCaveInSite defNames.
    -->
    <WorldObjectDef ParentName="StaticWorldObjectBase">
        <defName>DFP_TunnelCaveInSite</defName>
        <label>tunnel cave-in</label>
        <worldObjectClass>CaravansBattlefield</worldObjectClass>
        <mapGenerator>DFP_TunnelCaveIn</mapGenerator>
        <texture>UI/DFP_TunnelIcon</texture>
        <expandingIconTexture>UI/DFP_TunnelIcon</expandingIconTexture>
        <expandingIcon>true</expandingIcon>
        <expandingIconPriority>80</expandingIconPriority>
        <isTempIncidentMapOwner>true</isTempIncidentMapOwner>
        <comps>
            <li Class="WorldObjectCompProperties_FormCaravan" />
            <li Class="WorldObjectCompProperties_TimedDetectionRaids" />
        </comps>
    </WorldObjectDef>

    <WorldObjectDef>
        <defName>DFP_TunnelCaravanWorldObject</defName>
        <label>tunnel caravan</label>
        <description>A group of people travelling through tunnels in a minecart.</description>
        <worldObjectClass>DwarfFlavourPack.TunnelCaravan</worldObjectClass>
        <texture>UI/DFP_MineCart</texture>
        <useDynamicDrawer>true</useDynamicDrawer>
        <expandingIconTexture>UI/DFP_MineCart</expandingIconTexture>
        <expandingIcon>true</expandingIcon>
        <expandingIconPriority>100</expandingIconPriority>
        <expandMore>true</expandMore>
        <mapGenerator>Encounter</mapGenerator>
        <allowCaravanIncidentsWhichGenerateMap>true</allowCaravanIncidentsWhichGenerateMap>
        <IncidentTargetTags>
            <li>DFP_TunnelEntrance</li>
        </IncidentTargetTags>
        <inspectorTabs>
            <li>WITab_Caravan_Health</li>
            <li>WITab_Caravan_Needs</li>
            <li>WITab_Caravan_Gear</li>
            <li>WITab_Caravan_Social</li>
            <li>WITab_Caravan_Items</li>
            <li>WITab_Caravan_Feeding</li>
        </inspectorTabs>
    </WorldObjectDef>
</Defs>