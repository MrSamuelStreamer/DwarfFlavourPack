<?xml version="1.0" encoding="utf-8"?>

<Patch>

  <Operation Class="PatchOperationReplace">
		<xpath>Defs/ResearchProjectDef[defName="Electricity"]/techLevel</xpath>
		<value>
			<techLevel>Medieval</techLevel>
		</value>
	</Operation>
  <Operation Class="PatchOperationReplace">
		<xpath>Defs/ResearchProjectDef[defName="Electricity"]/label</xpath>
		<value>
			<label>Power</label>
		</value>
	</Operation>
  <Operation Class="PatchOperationReplace">
		<xpath>Defs/ResearchProjectDef[defName="Electricity"]/description</xpath>
		<value>
			<description>Some ES-like fluff description for power</description>
		</value>
	</Operation>

  <!-- Totally Safe Dwemer Fungus - prevents it from being used in meal recipes -->
  <Operation Class="PatchOperationAdd">
		<xpath>Defs/RecipeDef[@Name="CookMealBase"]/fixedIngredientFilter</xpath>
		<value>
			<disallowedThingDefs>
        <li>MSSD_TotallySafeDwemerFungus</li>
      </disallowedThingDefs>
		</value>
	</Operation>

  <!-- Basegame quest flavours -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestScriptDef[defName="ThreatReward_GameCondition_ItemPod"]/questDescriptionRules/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>questDescription(askerIsNull==true)->A powerful mage wants to perform some environmental experiments. However, if she carries out her experiment, [gameConditionDescriptionFuture].\n\nShe is concerned about getting in trouble with the council of mages, and is asking for your consent.</li>
        <li>questDescription(asker_factionLeader==True)->A vengeful Daedra is threatening the [asker_faction_pawnsPlural] of [asker_faction_name]. [asker_faction_leaderTitle] [asker_nameFull] wants you to send a message to the dark spirit accepting responsibility for their transgressions.\n\nIf you do, the Daedra will turn its anger on you. [gameConditionDescriptionFuture].</li>
        <li>questDescription(asker_royalInCurrentFaction==True)->[asker_nameFull], a [asker_royalTitleInCurrentFaction] of [asker_faction_name], wants to test a destructive, experimental sorcery spell. If [asker_pronoun] does, [gameConditionDescriptionFuture].\n\nSince you are a local landholder under imperial law, [asker_nameDef] needs your honorable permission to proceed.</li>
      </rulesStrings>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/GameConditionDef[defName="WeatherController"]/descriptionFuture</xpath>
    <value>
      <descriptionFuture>a weather-control spell will force the weather around [map_definite] to be [forcedWeather_indefinite] for [gameConditionDuration_duration]</descriptionFuture>
    </value>
  </Operation>
  <!-- can't remember if this one is yeeted in the modpack, commented out until further notice
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/GameConditionDef[defName="EMIField"]/descriptionFuture</xpath>
    <value>
      <descriptionFuture>a distant mage will blast [map_definite] with a magical interference field, shutting down powered devices for [gameConditionDuration_duration]</descriptionFuture>
    </value>
  </Operation> -->

  <!-- Site incidents -->

  <!-- Toxic spewer -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/QuestScriptDef[defName="Util_GenerateSite"]/root/singleSitePartRules/rulesStrings/li[contains(text(), 'sitePart==ToxicSpewer')]</xpath>
    <value>
      <li>root(priority=1,sitePart==ToxicSpewer)->there's (*Threat)a mysterious blight(/Threat) originating there blanketing the whole region in poison</li>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="ToxicSpewer"]/size</xpath>
    <value>
      <size>(5,5)</size>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="ToxicSpewer"]/graphicData/drawOffset</xpath>
    <value>
      <drawOffset>(0,0,-0.2)</drawOffset>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="ToxicSpewer"]/label</xpath>
    <value>
      <label>Cauldron of miasma</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="ToxicSpewer"]/description</xpath>
    <value>
      <description>An enormous ritual cauldron.\n\nA festering substance brewis within, releasing a toxic miasma that poisons everything across the region.</description>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="ToxicSpewer"]/graphicData/texPath</xpath>
    <value>
      <texPath>Things/Building/Production/Pot/SlopPot_south</texPath>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/GameConditionDef[defName="ToxicSpewer"]/label</xpath>
    <value>
      <label>mysterious blight</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/GameConditionDef[defName="ToxicSpewer"]/description</xpath>
    <value>
      <description>A mysterious blight nearby is blanketing this whole region with poison.</description>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/GameConditionDef[defName="ToxicSpewer"]/letterText</xpath>
    <value>
      <letterText>A mysterious blight has begun blanketing the whole region with poison.</letterText>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/SitePartDef[defName="ToxicSpewer"]/label</xpath>
    <value>
      <label>mysterious blight</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/SitePartDef[defName="ToxicSpewer"]/description</xpath>
    <value>
      <description>A mysterious blight.</description>
    </value>
  </Operation>

</Patch>