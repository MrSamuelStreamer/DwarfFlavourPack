<?xml version="1.0" encoding="utf-8"?>
<!-- Alp = Falmer -->

<!-- MO MOD -->
<Patch>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_Alp"]/label</xpath>
    <value>
      <label>Falmer</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_Alp"]/description</xpath>
    <value>
      <description>Falmer are blind, corrupted descendants of ancient Snow Elves that now live deep beneath the surface.\nThey are known to stalk and attack intruders, primarily in - but not limited to - underground Dwemer ruins.\n\nTheir ancestors, the Snow Elves, were betrayed in a deal for asylum they struck with the Dwemer, after having been displaced by invading Nords.\nThe Dwemer forced their wards to subsist only on toxic fungi which twisted them into what they are today.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/PawnKindDef[defName="DankPyon_Alp"]/label</xpath>
    <value>
      <label>Falmer</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/PawnKindDef[defName="DankPyon_Alp"]/labelPlural</xpath>
    <value>
      <labelPlural>Falmer</labelPlural>
    </value>
  </Operation>

<!-- MAH MOD -->

  <!-- bloody letter loot -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Seti_loot_letteralp"]/label</xpath>
    <value>
      <label>bloody letter (Falmer)</label>
    </value>
  </Operation>

  <!-- map stuff -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setialpruinA"]/label</xpath>
    <value>
      <label>Ruined Farm</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setialpruinA"]/description</xpath>
    <value>
      <description>A large farm that was recently destroyed in an apparent raid. Settlements nearby have labelled the general area a no-go zone, as they have reportedly sent armed guards to investigate, but whom never returned.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setialpruinB"]/label</xpath>
    <value>
      <label>Ruined Tavern</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setialpruinB"]/description</xpath>
    <value>
      <description>A large, relatively-famous tavern that has been recently destroyed in an attack. A nearby settlement has reported seeing lit campfires around the site, and suggested that it must be the work of slavers, or bandits.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setialpruinC"]/label</xpath>
    <value>
      <label>Ruined site</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setialpruinC"]/description</xpath>
    <value>
      <description>A seemingly-abandoned trading camp, there have been recent reports of ambushes on travellers nearby.\nA nearby settlement has suggested bandits, but a hysterical travelling merchant has sworn to sightings of goblin-like creatures.</description>
    </value>
  </Operation>

  <!-- caravan actions -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CaravanActionDef[defName="setilocatealp"]/label</xpath>
    <value>
      <label>Locate mysterious bandits</label>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CaravanActionDef[defName="setilocatealp"]/description</xpath>
    <value>
      <description>Track down sites of mysterious bandits causing chaos in the local area.</description>
    </value>
  </Operation>

  <!-- quests -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestScriptDef[defName="seti_alpquest"]/questDescriptionRules/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>questDescription -> Banditry has been reported by nearby settlements, who are unable to put a stop to it. We should go investigate.</li>
      </rulesStrings>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestScriptDef[defName="seti_alpquest"]/questNameRules/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>questName(p=3)->[complexAdj] [complex]</li>
				<li>questName->[complex]</li>
				<li>complexAdj->bloody</li>
				<li>complexAdj->screaming</li>
				<li>complexAdj->hidden</li>
				<li>complexAdj->haunted</li>
				<li>complex->ruin</li>
				<li>complex->community</li>
				<li>complex->mysterious bandits</li>
      </rulesStrings>
    </value>
  </Operation>

</Patch>