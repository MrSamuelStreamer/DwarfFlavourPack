<?xml version="1.0" encoding="utf-8"?>
<!-- Lindwurm = Drake -->

<!-- MO MOD -->
<Patch>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_LindwurmForest"]/label</xpath>
    <value>
      <label>forest drake</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_LindwurmForest"]/description</xpath>
    <value>
      <description>An enormous reptile, halfway between serpents and dragons. One of the few creatures truly incapable of feeling fear. Any daredevil who manages to get past the mighty yet nimble tail and pierce a hardy scale will be splashed with corrosive blood. Drake blood is the most powerful acid known yet - dissolving even the thickest steel, eating through the flesh in seconds.</description>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_LindwurmCave"]/label</xpath>
    <value>
      <label>cave drake</label>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/PawnKindDef[defName="DankPyon_LindwurmForest"]/label</xpath>
    <value>
      <label>forest drake</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/PawnKindDef[defName="DankPyon_LindwurmCave"]/label</xpath>
    <value>
      <label>cave drake</label>
    </value>
  </Operation>

<!-- MAH MOD -->

  <!-- bloody letter loot -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Seti_loot_lettervenomed"]/label</xpath>
    <value>
      <label>bloody letter (Drake)</label>
    </value>
  </Operation>

  <!-- map stuff -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setilindwurmlairA"]/label</xpath>
    <value>
      <label>Drake ruins</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setilindwurmlairA"]/description</xpath>
    <value>
      <description>A ruin overtaken by an enormous Drake.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setilindwurmlairB"]/label</xpath>
    <value>
      <label>Drake cave</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setilindwurmlairB"]/description</xpath>
    <value>
      <description>An inconspicuous cave. A large Drake reportedly dwells inside.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setilindwurmlairC"]/label</xpath>
    <value>
      <label>Drake hatchery</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CustomMapDataDef[defName="setilindwurmlairC"]/description</xpath>
    <value>
      <description>A large site which reportedly houses a hatchery for the terrifying Drake.</description>
    </value>
  </Operation>

  <!-- caravan actions -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CaravanActionDef[defName="setilocatelindwurm"]/label</xpath>
    <value>
      <label>Locate Drake</label>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestEditor_Library.CaravanActionDef[defName="setilocatelindwurm"]/description</xpath>
    <value>
      <description>Track down a Drake.</description>
    </value>
  </Operation>

  <!-- quests -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestScriptDef[defName="seti_lindwurmquest"]/questDescriptionRules/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>questDescription -> We tracked down a nest of the savage Drake. Incomprehensibly perilous, we should thoroughly prepare before proceeding. Drake venom, in particular, is extremely dangerous.</li>
      </rulesStrings>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestScriptDef[defName="seti_lindwurmquest"]/questNameRules/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>questName(p=3)->[complexAdj] [complex]</li>
				<li>questName->[complex]</li>
				<li>complexAdj->bloody</li>
				<li>complexAdj->venomous</li>
				<li>complexAdj->dusty</li>
				<li>complexAdj->dangerous</li>
				<li>complexAdj->poisonous</li>
				<li>complex->drake palace</li>
				<li>complex->drake temple</li>
				<li>complex->drake's subjects</li>
      </rulesStrings>
    </value>
  </Operation>

</Patch>