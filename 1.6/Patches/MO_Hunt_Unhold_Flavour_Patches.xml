<?xml version="1.0" encoding="utf-8"?>
<!-- Unhold = Ogre -->

<!-- MO MOD -->
<Patch>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_Unhold"]/label</xpath>
    <value>
      <label>Ogre</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_Unhold"]/description</xpath>
    <value>
      <description>The Ogre is a towering giant, three times the size of a man, known for devouring sheep and draining ponds in a single gulp. Though tales paint them as destructive, they're not inherently malicious, preferring to scare off intruders with deafening roars rather than attacking. Usually solitary, Ogres are found alone or in small groups, fiercely defending their territory.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_UnholdSnow"]/label</xpath>
    <value>
      <label>ogre</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="DankPyon_UnholdSnow"]/description</xpath>
    <value>
      <description>The Ogre is a towering giant, three times the size of a man, known for devouring sheep and draining ponds in a single gulp. Though tales paint them as destructive, they're not inherently malicious, preferring to scare off intruders with deafening roars rather than attacking. Usually solitary, Ogres are found alone or in small groups, fiercely defending their territory.</description>
    </value>
  </Operation>

