      <rulesStrings>
        <li>questDescription -> We have tracked the location of a small community of ogres. Their reputation for ferocity is well-deserved; we'd best prepare well.</li>
      </rulesStrings>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/QuestScriptDef[defName="seti_unholdquest"]/questNameRules/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>questName(p=3)->[complexAdj] [complex]</li>
				<li>questName->[complex]</li>
				<li>complexAdj->isolated</li>
				<li>complexAdj->defensive</li>
				<li>complexAdj->agressive</li>
				<li>complexAdj->primitive</li>
				<li>complexAdj->strong</li>
				<li>complex->ogre community</li>
				<li>complex->ogre grounds</li>
				<li>complex->ogres</li>
