<?xml version="1.0" encoding="utf-8" ?>
<!--
  Adds DFP_TunnelEntrance to the allowedTargetTags of the three caravan/temp-map
  StorytellerCompProperties_CategoryIndividualMTBByBiome comps (Misc, ThreatSmall,
  ThreatBig) in each vanilla storyteller (Cassandra, Phoebe, Randy).

  This is required because Storyteller.MakeIncidentsForInterval only calls
  MakeIntervalIncidents(target) when the comp's allowedTargetTags intersects the
  target's IncidentTargetTags(). TunnelCaravan exposes only DFP_TunnelEntrance,
  so without this patch no comp ever fires for it and our incident defs are dead code.

  The vanilla Caravan incidents (targetTags=[Caravan]) are NOT selected for
  TunnelCaravan because UsableIncidentsInCategory calls TargetAllowed, which checks
  incident.targetTags.Intersect(target.IncidentTargetTags()). Since TunnelCaravan
  only has [DFP_TunnelEntrance], vanilla incidents with targetTags=[Caravan] won't
  match. Our workers' CanFireNowSub provides a second guard anyway.
-->
<Patch>

  <!-- ══════════════════════════════════════════════════════════════════
       Cassandra
       ══════════════════════════════════════════════════════════════════ -->

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Cassandra"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="Misc"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Cassandra"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="ThreatSmall"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Cassandra"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="ThreatBig"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <!-- ══════════════════════════════════════════════════════════════════
       Phoebe
       ══════════════════════════════════════════════════════════════════ -->

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Phoebe"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="Misc"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Phoebe"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="ThreatSmall"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Phoebe"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="ThreatBig"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <!-- ══════════════════════════════════════════════════════════════════
       Randy
       ══════════════════════════════════════════════════════════════════ -->

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Randy"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="Misc"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Randy"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="ThreatSmall"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[defName="Randy"]/comps/li[@Class="StorytellerCompProperties_CategoryIndividualMTBByBiome" and category="ThreatBig"]/allowedTargetTags</xpath>
    <value>
      <li>DFP_TunnelEntrance</li>
    </value>
  </Operation>

</Patch>
